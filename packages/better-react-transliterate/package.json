{
  "name": "better-react-transliterate",
  "version": "1.2.0",
  "description": "SSR-friendly transliteration input for React",
  "author": "biomathcode (sharma.pratik2016@gmail.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/biomathcode/react-transliterate.git",
    "directory": "packages/better-react-transliterate"
  },
  "homepage": "https://github.com/biomathcode/react-transliterate/tree/main/packages/better-react-transliterate",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "react",
    "transliterate",
    "input",
    "ssr",
    "nextjs",
    "english to hindi"
  ],
  "scripts": {
    "build": "tsup ",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "textarea-caret": "^3.1.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/textarea-caret": "^3.0.4",
    "jsdom": "^29.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  }
}